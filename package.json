{
    "name": "@modular/app",
    "productName": "Operator",
    "version": "0.0.112",
    "description": "Operator - a real-time modular synthesizer desktop app with a JavaScript DSL for live-coding audio patches",
    "main": ".vite/build/main.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/HelveticaScenario/operator"
    },
    "scripts": {
        "start": "yarn build-native && yarn build-syphon-bridge && concurrently --handle-input --default-input-target app -n app,rust -c blue,yellow 'node scripts/start-dev.mjs' 'yarn watch-native'",
        "start:debug": "yarn build-native-debug && electron-forge start --inspect-electron",
        "start:no-watch": "yarn build-native && electron-forge start",
        "profile": "yarn build-native-profile && electron-forge start",
        "start:alloc": "yarn build-native-alloc && yarn build-syphon-bridge && concurrently --handle-input --default-input-target app -n app,rust -c blue,yellow 'node scripts/start-dev.mjs' 'yarn watch-native-alloc'",
        "package": "yarn build-native && yarn build-syphon-bridge --require && electron-forge package",
        "make": "yarn build-native && yarn build-syphon-bridge --require --universal && electron-forge make",
        "forge-publish": "yarn build-native && yarn build-syphon-bridge --require --universal && electron-forge publish",
        "build-syphon-bridge": "node scripts/build-syphon-bridge.mjs",
        "deploy": "./release.sh",
        "test": "yarn test:unit",
        "test:unit": "vitest run",
        "test:rust": "yarn gen:sp-fixtures && cargo test",
        "test:e2e": "playwright test",
        "test:e2e:update": "playwright test --update-snapshots",
        "test:all": "yarn test:unit && yarn test:rust && yarn test:e2e",
        "typecheck": "yarn build-native && tsc -b",
        "lint": "oxlint src --config .oxlintrc.json -A tsconfig-error",
        "lint:fix": "oxlint src --fix --config .oxlintrc.json -A tsconfig-error",
        "knip": "knip",
        "rebuild": "yarn build-native && electron-rebuild -f -w modular-core",
        "watch-native": "node scripts/watch-native.mjs",
        "watch-native-alloc": "node scripts/watch-native.mjs --features=alloc-detector",
        "build-native": "cd crates/modular && yarn build",
        "build-native-debug": "cd crates/modular && yarn build:debug",
        "build-native-profile": "cd crates/modular && yarn build --features=tracy",
        "build-native-alloc": "cd crates/modular && yarn build:alloc",
        "build:grammar": "node scripts/buildGrammar.mjs",
        "gen:sp-fixtures": "node scripts/gen-sp-fixture.mjs",
        "gen:parser-parity-fixture": "vitest run src/main/dsl/miniNotation/__tests__/peggy_parser_parity_fixture.test.ts --reporter=verbose",
        "generate-lib": "yarn build-native && tsx scripts/generateLib.ts",
        "postinstall": "node scripts/patch-electron-plist.mjs",
        "prepare": "husky"
    },
    "keywords": [],
    "author": {
        "name": "Daniel Lewis",
        "email": "daniel.lewis.software.engineer@gmail.com"
    },
    "license": "AGPL",
    "devDependencies": {
        "@electron-forge/cli": "^7.10.2",
        "@electron-forge/maker-deb": "^7.10.2",
        "@electron-forge/maker-flatpak": "^7.10.2",
        "@electron-forge/maker-rpm": "^7.10.2",
        "@electron-forge/maker-squirrel": "^7.10.2",
        "@electron-forge/maker-zip": "^7.10.2",
        "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
        "@electron-forge/plugin-fuses": "^7.10.2",
        "@electron-forge/plugin-vite": "^7.11.1",
        "@electron-forge/publisher-github": "^7.10.2",
        "@electron/fuses": "^1.8.0",
        "@electron/notarize": "^3.1.1",
        "@electron/osx-sign": "^2.3.0",
        "@playwright/test": "^1.58.2",
        "@strudel/core": "1.2.5",
        "@strudel/mini": "1.2.5",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/electron-squirrel-startup": "^1.0.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "concurrently": "^9.2.1",
        "electron": "39.2.7",
        "eslint-plugin-react-hooks": "^7.0.1",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "knip": "^6.1.1",
        "lint-staged": "^16.2.7",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.19.0",
        "peggy": "^5.1.0",
        "tsx": "^4.21.0",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@fontsource/anonymous-pro": "^5.2.8",
        "@fontsource/cascadia-code": "^5.2.3",
        "@fontsource/commit-mono": "^5.2.5",
        "@fontsource/fira-code": "^5.2.7",
        "@fontsource/geist-mono": "^5.2.7",
        "@fontsource/ibm-plex-mono": "^5.2.7",
        "@fontsource/inconsolata": "^5.2.8",
        "@fontsource/iosevka": "^5.2.5",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@fontsource/maple-mono": "^5.2.6",
        "@fontsource/monaspace-argon": "^5.2.5",
        "@fontsource/monaspace-krypton": "^5.2.5",
        "@fontsource/monaspace-neon": "^5.2.5",
        "@fontsource/monaspace-radon": "^5.2.5",
        "@fontsource/monaspace-xenon": "^5.2.5",
        "@fontsource/mononoki": "^5.2.5",
        "@fontsource/recursive": "^5.2.8",
        "@fontsource/roboto-mono": "^5.2.8",
        "@fontsource/source-code-pro": "^5.2.7",
        "@fontsource/victor-mono": "^5.2.8",
        "@monaco-editor/react": "^4.7.0",
        "@tanstack/react-table": "^8.21.3",
        "cmdk": "^1.1.1",
        "electron-squirrel-startup": "^1.0.1",
        "jsonc-parser": "^3.3.1",
        "monaco-editor": "^0.55.1",
        "prettier": "^3.8.4",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-markdown": "^10.1.0",
        "tinykeys": "^3.0.0",
        "ts-morph": "^27.0.2",
        "typescript": "~5.9.3",
        "uuid": "^13.0.0",
        "zod": "^4.3.5"
    },
    "workspaces": [
        "crates/*"
    ],
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,json,css,md}": [
            "yarn lint:fix",
            "prettier --write"
        ],
        "crates/modular/*.rs": [
            "cargo fmt --check --manifest-path crates/modular/Cargo.toml",
            "cargo fmt --allow-staged --manifest-path crates/modular/Cargo.toml"
        ],
        "crates/modular_core/*.rs": [
            "cargo fmt --check --manifest-path crates/modular_core/Cargo.toml",
            "cargo fmt --allow-staged --manifest-path crates/modular_core/Cargo.toml"
        ],
        "crates/modular_derive/*.rs": [
            "cargo fmt --check --manifest-path crates/modular_derive/Cargo.toml",
            "cargo fmt --allow-staged --manifest-path crates/modular_derive/Cargo.toml"
        ]
    },
    "packageManager": "yarn@4.12.0",
    "volta": {
        "node": "24.12.0",
        "yarn": "4.12.0"
    }
}
